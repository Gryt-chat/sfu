# SFU Server Configuration

# Port for the SFU server
PORT=5005

# STUN servers (comma separated)
STUN_SERVERS=stun:stun.l.google.com:19302

# Recommended: run ICE/media over a single UDP port (open/allow this port on the SFU host firewall)
# ICE_UDP_MUX_PORT=443

# Alternative: pin the UDP port range used for WebRTC media (open/allow this range on the SFU host firewall)
# Example: ~200 "seats"
ICE_UDP_PORT_MIN=10000
ICE_UDP_PORT_MAX=10019

# Optional: hard-cap the number of connected peers (defaults to size of ICE_UDP_PORT_* range if set)
# MAX_PEERS=200

# Optional: force the IP address(es) the SFU advertises in ICE host candidates.
# Use this when the SFU is behind NAT or you want to ensure it never advertises an unintended public IP.
# Comma-separated for multi-network (e.g. public + LAN); ICE will generate
# candidates for each IP and clients pick the best path automatically.
# ICE_ADVERTISE_IP=203.0.113.10
# ICE_ADVERTISE_IP=203.0.113.10,192.168.1.100

# Disable server-side STUN (prevents srflx candidate discovery).
# Safe only when the SFU has a direct, port-preserving path to the internet
# (host networking, bare metal, 1:1 NAT).  With Docker or cloud NAT the
# external port often differs from ICE_UDP_MUX_PORT, so keep STUN enabled.
# DISABLE_STUN=true

# Debug logging (true/false) - shows detailed room management, connections, signaling
DEBUG=true

# Verbose logging (true/false) - shows RTP packet forwarding details
VERBOSE_LOG=false 